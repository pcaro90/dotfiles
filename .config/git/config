[user]
    name = Pablo Caro
    email = me@pcaro.es

[alias]
    a = add
    h = help

    b = branch
    bv = branch -v
    sw = switch

    c = commit
    ca = commit --amend
    cm = commit -m
    cam = commit --amend -m

    cl = clone

    co = checkout
    cob = checkout -b
    co- = checkout --

    ce = config -e

    d = diff
    dc = diff --cached
    ds = diff --staged
    dl = diff HEAD~1

    pl = pull
    ps = push

    r = remote -v
    s = status

    l  = log --graph --abbrev-commit --decorate --all --format=format:'%C(bold magenta)%h%Creset - %s %C(bold green)(%ar) %C(yellow)%d%Creset'
    l2  = log --graph --abbrev-commit --decorate --all --format=format:'%C(bold magenta)%h%Creset - %C(cyan)%ai%Creset %C(bold green)(%ar) %C(yellow)%d%Creset%n    %s%Creset  - %C(bold blue)%an%Creset <%C(dim blue)%ae%Creset>'


[color]
     ui = auto

[core]
    compression = 9
    whitespace = error
    preloadindex = true
    excludesfile = ~/.config/git/gitignore_global
    pager = delta

[init]
    defaultBranch = main

[push]
    default = simple
    autoSetupRemote = true

[filter "lfs"]
    process = git-lfs filter-process
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f

[interactive]
    diffFilter = delta --color-only

[merge]
    conflictStyle = zdiff3

[delta]
    navigate = true
    dark = true
    line-numbers = true

    # Tokyonight moon
    minus-style                   = syntax "#4b2a3d"
    minus-non-emph-style          = syntax "#4b2a3d"
    minus-emph-style              = syntax "#6b2e43"
    minus-empty-line-marker-style = syntax "#4b2a3d"
    line-numbers-minus-style      = "#e26a75"
    plus-style                    = syntax "#2a4556"
    plus-non-emph-style           = syntax "#2a4556"
    plus-emph-style               = syntax "#305f6f"
    plus-empty-line-marker-style  = syntax "#2a4556"
    line-numbers-plus-style       = "#b8db87"
    line-numbers-zero-style       = "#3b4261"
